{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Silent Failure Museum — Exhibit",
  "type": "object",
  "required": ["id", "title", "hall", "date", "badge", "summary", "sources", "verifierMapping", "trace"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "hall": {
      "type": "string",
      "enum": ["destruction", "silent-wrong-output", "supply-chain", "delivery", "annex"]
    },
    "date": { "type": "string", "description": "ISO date of the incident/class." },
    "badge": {
      "type": "string",
      "enum": ["documented", "reconstruction", "composite"],
      "description": "documented = sourced first-hand; reconstruction = steps reconstructed; composite = representative of a class."
    },
    "status": { "type": "string", "enum": ["draft", "published"] },
    "summary": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "date"],
        "properties": {
          "url": { "type": "string" },
          "date": { "type": "string" },
          "title": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      }
    },
    "verifierMapping": {
      "type": "array",
      "description": "Which Blackbox verifier / guardrail class would have caught this.",
      "items": { "type": "string" }
    },
    "trace": {
      "type": "object",
      "required": ["traceVersion"],
      "description": "A Trace Schema v1 reconstruction rendered by the trace player.",
      "properties": { "traceVersion": { "const": "1.0" } }
    }
  }
}
